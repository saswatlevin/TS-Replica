{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "./",
    "outDir": "./dist",
    "lib": ["ES2020"],
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "server.ts",
    "server.js",
    "Middleware/**/*.ts",
    "Middleware/**/*.js"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/__tests__/**"
  ]
}

